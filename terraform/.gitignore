# Terraform gitignore

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Backup files
*.tfbackup
*.backup

# Variable files with secrets
**/terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Keep examples
!terraform.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# Plans
*.tfplan
*.tfplan.*
plan.out

# CLI configuration files
.terraformrc
terraform.rc

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
