{
  "name": "react-fil-rouge-backend",
  "version": "1.0.0",
  "description": "API REST Express et MongoDB pour react-fil-rouge",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "test": "jest --coverage --coverageDirectory=coverage --forceExit",
    "test:ci": "jest --coverage --coverageDirectory=coverage --forceExit --ci"
  },
  "keywords": [
    "node",
    "express",
    "mongodb",
    "mongoose",
    "rest-api"
  ],
  "author": "Seydina Laye",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.2",
    "multer": "^2.0.2",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.10",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "coverage",
          "outputName": "junit.xml"
        }
      ]
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "coverageReporters": [
      "lcov",
      "text",
      "clover"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "server.js",
      "!src/__tests__/**",
      "!src/config/**",
      "!src/middleware/upload.js",
      "!scripts/**"
    ]
  }
}
