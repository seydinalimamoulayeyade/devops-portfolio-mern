{
  "uid": "devops-portfolio",
  "title": "DevOps Portfolio — Application",
  "tags": ["devops-portfolio", "mern", "application"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Backend en ligne",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(up{job=\"backend-app\"})" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Projets en base (réel)",
      "description": "Nombre réel de projets stockés en base (jauge rafraîchie à chaque scrape). Robuste aux redémarrages du pod, contrairement au compteur cumulé.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(portfolio_projects_count)" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connexions réussies",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(auth_login_attempts_total{result=\"success\"})" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Connexions échouées (sécurité)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 } ] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(auth_login_attempts_total{result=~\"failure|error\"})" }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Taux de succès des connexions (%)",
      "description": "Part des connexions réussies sur l'ensemble des tentatives depuis le démarrage. Une chute peut signaler un bug d'auth ou une attaque par force brute.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 50 }, { "color": "green", "value": 80 } ] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * sum(auth_login_attempts_total{result=\"success\"}) / sum(auth_login_attempts_total)" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Projets créés (cumul événements)",
      "description": "Compteur d'événements de création depuis le dernier (re)démarrage du pod. Repart à zéro si le backend redémarre.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(projects_created_total)" }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Redémarrages de pods (cumul)",
      "description": "Somme des redémarrages de conteneurs dans le namespace de l'application. Un nombre qui grimpe = crash-loop (ex. OOM).",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 } ] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"devops-portfolio-dev\"})" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Trafic — requêtes/s par route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total[5m])) by (route)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latence p95 par route (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Taux d'erreurs 5xx (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 5 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * (sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])))", "legendFormat": "erreurs 5xx %" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Connexions par résultat (par seconde)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(auth_login_attempts_total[5m])) by (result)", "legendFormat": "{{result}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Redémarrages de pods par pod (cumul)",
      "description": "Évolution du nombre de redémarrages par pod de l'application. Une marche d'escalier = un nouveau crash.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"devops-portfolio-dev\"}) by (pod)", "legendFormat": "{{pod}}" }
      ]
    }
  ]
}
